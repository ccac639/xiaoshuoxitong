# SiliconFlow API 配置模板（复制为 .env.local 后填入真实 key）
# 获取地址：https://siliconflow.cn/ 控制台 → API Keys
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 智谱 BigModel API 配置模板
# 获取地址：https://open.bigmodel.cn/ 控制台 → API Keys
# 免费模型 GLM-4.7-Flash（200K 上下文），需在请求中关闭思考模式才会直出正文
ZHIPU_API_KEY=your-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# OpenRouter API 配置模板（聚合多厂商，含免费国内模型）
# 获取地址：https://openrouter.ai/keys
# 免费国内模型：tencent/hy3:free、qwen/qwen3-coder:free、qwen/qwen3-next-80b-a3b-instruct:free
# 注：推理模型需关闭思考（chat_template_kwargs.enable_thinking=false）才会产出正文
OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
