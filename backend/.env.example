# AI Novel OS Lite 后端 v2.1 环境变量模板
# 复制为 .env 后按需修改（.env 已被 gitignore，切勿提交真实密钥）

# 数据库连接（容器间用服务名 postgres；本机直跑用 localhost）
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/xiaoshuoxitong

# 缓存 / 任务队列
REDIS_URL=redis://redis:6379/0

# 向量维度（与嵌入模型保持一致）
EMBEDDING_DIM=1536

# API 前缀与 CORS
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# LLM Provider 密钥（v2.3+ 启用；v2.1 阶段不使用，留空）
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
MOMA_API_KEY=
